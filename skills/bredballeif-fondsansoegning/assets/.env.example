# Kopiér kun nøglerne til repoets gitignored .env eller sæt dem i runtime-miljøet.
FUNDRAISINGCLUB_USERNAME=
FUNDRAISINGCLUB_PASSWORD=
FUNDRAISINGCLUB_BASE_URL=https://app.fundraisingclub.dk
